# Instapaper Credentials
# Copy this file to .env and fill in your actual credentials

# Your Instapaper username (email)
INSTAPAPER_USERNAME=your_email@example.com

# Your Instapaper password
INSTAPAPER_PASSWORD=your_password

# Instapaper API Consumer Key
INSTAPAPER_CONSUMER_KEY=your_consumer_key

# Instapaper API Consumer Secret
INSTAPAPER_CONSUMER_SECRET=your_consumer_secret

# Speak Mode Configuration
# Maximum line width for text wrapping in speak mode (default: 70)
SPEAK_LINE_WIDTH=70

# Optional voice command + Daily transport configuration
# DAILY_ROOM_URL=https://your-domain.daily.co/your-room
# DAILY_TOKEN=your_daily_token
# DEEPGRAM_API_KEY=your_deepgram_api_key
# EMPTY_ROOM_SHUTDOWN_SECONDS=90

# Optional TTS vendor selection for Daily transport
# Supported values: cartesia, elevenlabs
# IP_CONDUCTOR_TTS_VENDOR=cartesia

# Cartesia TTS credentials (used when --tts-vendor cartesia)
# CARTESIA_API_KEY=your_cartesia_api_key
# CARTESIA_VOICE_ID=your_cartesia_voice_id

# ElevenLabs TTS credentials (used when --tts-vendor elevenlabs)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
