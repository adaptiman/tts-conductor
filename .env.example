# Copy this file to .env and fill in your actual values.

# -----------------------------------------------------------------------------
# Instapaper credentials (required for article access)
# -----------------------------------------------------------------------------
INSTAPAPER_USERNAME=your_email@example.com
INSTAPAPER_PASSWORD=your_password
INSTAPAPER_CONSUMER_KEY=your_consumer_key
INSTAPAPER_CONSUMER_SECRET=your_consumer_secret

# -----------------------------------------------------------------------------
# Core app settings
# -----------------------------------------------------------------------------
SPEAK_LINE_WIDTH=70

# Optional default input device for local voice mode.
# Use python ip_conductor.py --list-audio-devices to find index.
# IP_CONDUCTOR_INPUT_DEVICE_INDEX=0

# -----------------------------------------------------------------------------
# Daily transport + STT/TTS provider credentials
# -----------------------------------------------------------------------------
# Optional Daily room transport settings.
# DAILY_ROOM_URL=https://your-domain.daily.co/your-room
# DAILY_TOKEN=your_daily_token
# DAILY_API_KEY=your_daily_api_key

# STT key (required for deepgram provider).
# DEEPGRAM_API_KEY=your_deepgram_api_key

# Default TTS vendor for Daily mode: cartesia or elevenlabs.
IP_CONDUCTOR_TTS_VENDOR=cartesia

# Cartesia credentials (required when using cartesia).
# CARTESIA_API_KEY=your_cartesia_api_key
# CARTESIA_VOICE_ID=your_cartesia_voice_id

# ElevenLabs credentials (required when using elevenlabs).
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Auto-exit after room is empty for this many seconds in Daily/headless mode.
EMPTY_ROOM_SHUTDOWN_SECONDS=45

# -----------------------------------------------------------------------------
# Turn strategy and latency tuning (voice mode)
# -----------------------------------------------------------------------------
IP_CONDUCTOR_TURN_PROFILE=balanced
IP_CONDUCTOR_BARGE_IN_MODE=commands
IP_CONDUCTOR_COMMAND_EMIT_SOURCE=turn_stop
IP_CONDUCTOR_IDLE_TIMEOUT_SECONDS=120

# STT tuning
IP_CONDUCTOR_STT_PROVIDER=deepgram
IP_CONDUCTOR_STT_KEEPALIVE_SECONDS=20
IP_CONDUCTOR_STT_ENDPOINTING_MS=250
IP_CONDUCTOR_STT_UTTERANCE_END_MS=700

# TTS tuning
IP_CONDUCTOR_TTS_CONCURRENCY=1
IP_CONDUCTOR_TTS_TEXT_AGGREGATION_MODE=sentence

# Failover + metrics
IP_CONDUCTOR_FAILOVER_ENABLED=true
IP_CONDUCTOR_FAILOVER_CHAIN=deepgram,whisper
IP_CONDUCTOR_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Launcher / webhook bridge settings (used by launcher function + VM tooling)
# -----------------------------------------------------------------------------
# Shared secret between launcher clients and VM launcher.
# JOB_LAUNCHER_SHARED_SECRET=replace-with-a-long-random-secret

# Azure Function -> VM launcher relay settings.
# VM_LAUNCHER_BASE_URL=https://your-launcher-host:8443
# VM_LAUNCHER_TIMEOUT_SECONDS=15

# Daily webhook authorization/filter settings.
# DAILY_HOOK_SHARED_SECRET=optional-shared-secret
# DAILY_HOOK_HMAC_SECRET=optional-daily-hmac-secret
# DAILY_WEBHOOK_ROOM_NAME=optional-room-filter
# DAILY_HOOK_ENABLE_STOP_ACTION=false
# DAILY_HOOK_START_ON_UNRECOGNIZED_EVENT=true

# -----------------------------------------------------------------------------
# Deployment helper script options (vm/update-production.sh)
# -----------------------------------------------------------------------------
# HEALTHCHECK_RETRIES=12
# HEALTHCHECK_INTERVAL_SECONDS=5
