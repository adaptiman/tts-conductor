# Copy this file to vm/.env on the VM before running docker compose.

# Shared secret used by Azure Function and VM launcher service.
JOB_LAUNCHER_SHARED_SECRET=replace-with-a-long-random-secret

# Bot runtime container settings.
BOT_IMAGE=acrttsconductorprod.azurecr.io/tts-conductor:latest
BOT_CONTAINER_NAME=tts-conductor-bot
BOT_COMMAND=python ip_conductor.py --voice --voice-transport daily --headless
BOT_NETWORK=tts-conductor-bot-net
BOT_PULL_ON_START=true
BOT_MEMORY_LIMIT=850m
BOT_NANO_CPUS=700000000

# Host path to the bot's runtime .env file (mounted read-only into launcher).
BOT_ENV_SOURCE=../.env

# TODO: move runtime secrets from plain .env to a managed secret store.
