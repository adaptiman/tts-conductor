# Copy this file to vm/.env on the VM before running docker compose.

# Shared secret used to protect VM launcher control endpoints.
JOB_LAUNCHER_SHARED_SECRET=replace-with-a-long-random-secret

# Daily webhook auth settings for POST /daily-hook.
# Prefer DAILY_HOOK_HMAC_SECRET when available.
DAILY_HOOK_HMAC_SECRET=replace-with-daily-hmac-secret
# Optional fallback only when HMAC signing is unavailable:
# DAILY_HOOK_SHARED_SECRET=replace-with-daily-webhook-secret
# DAILY_WEBHOOK_ROOM_NAME=optional-room-filter
# DAILY_HOOK_ENABLE_STOP_ACTION=false
# DAILY_HOOK_START_ON_UNRECOGNIZED_EVENT=true

# Bot runtime container settings.
BOT_IMAGE=tts-conductor:local
BOT_CONTAINER_NAME=tts-conductor-bot
BOT_COMMAND=python ip_conductor.py --voice --voice-transport daily --headless
BOT_NETWORK=tts-conductor-bot-net
# Keep false by default for VM-local image operation.
BOT_PULL_ON_START=false
BOT_MEMORY_LIMIT=850m
BOT_NANO_CPUS=700000000

# Host path to the bot's runtime .env file (mounted read-only into launcher).
BOT_ENV_SOURCE=../.env

# TODO: move runtime secrets from plain .env to a managed secret store.
